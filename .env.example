# ═══════════════════════════════════════════════════════════════
# SecureBank Microservices — Environment Variables Template
# Copy this file to .env and fill in real values
# ═══════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────
DB_ROOT_PASSWORD=your_mysql_root_password
DB_USERNAME=root
DB_PASSWORD=your_mysql_root_password

# ── JWT ───────────────────────────────────────────────────────
# Minimum 32 characters
JWT_SECRET=MySecureBankJwtSecretKey2026VerySecure123456789
JWT_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000

# ── Mail (Gmail) ──────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_gmail_app_password

# ── Kafka ─────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# ── Eureka ────────────────────────────────────────────────────
EUREKA_URL=http://eureka-server:8761/eureka/

# ── File Upload ───────────────────────────────────────────────
FILE_UPLOAD_PATH=/app/uploads

# ── AI Service ────────────────────────────────────────────────
# Free key at: openrouter.ai
AI_API_KEY=sk-or-v1-your-openrouter-key
AI_BASE_URL=https://openrouter.ai/api
AI_MODEL=google/gemini-2.5-flash:free

# ── Spring Profiles ───────────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod